# Copy this file to .env and fill in real values. Never commit .env.

# PostgreSQL connection string used by Prisma.
DATABASE_URL="postgresql://user:password@localhost:5432/scholarsphere?schema=public"

# Gemini API key used by the chat/matching services (server-side only, never exposed to the client).
# Get one free at https://aistudio.google.com/apikey.
GEMINI_API_KEY="..."

# Model used for Nova's intent extraction + general Q&A. Optional — has a default, override if needed.
NOVA_MODEL="gemini-2.5-flash"

# Auth.js session encryption secret — generate your own with `openssl rand -base64 32`.
# Use a different secret per environment.
AUTH_SECRET="generate-your-own-with-openssl-rand--base64-32"
